<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:drawable="@drawable/id3_icon_shuffle_p" />
        </layer-list>
    </item>

    <!-- 禁用状态 -->
    <item android:state_enabled="false">
        <layer-list>
            <item android:drawable="@drawable/id3_icon_shuffle_d" />
        </layer-list>
    </item>

    <!-- 默认状态 -->
    <item>
        <layer-list>
            <item android:drawable="@drawable/id3_icon_shuffle_on_n" /> <!-- 图标 -->
        </layer-list>
    </item>
</selector>