<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <layer-list>
            <item android:drawable="@drawable/buttonbar_button_p" /> <!-- 背景 -->
            <item android:drawable="@drawable/buttonbar_icon_eq_n" /> <!-- 图标 -->
        </layer-list>
    </item>

    <!-- 聚焦状态 -->
    <item android:state_focused="true">
        <layer-list>
            <item android:drawable="@drawable/buttonbar_icon_eq_f" />
        </layer-list>
    </item>

    <!-- 禁用状态 -->
    <item android:state_enabled="false">
        <layer-list>
            <item android:drawable="@drawable/buttonbar_button_d" />
            <item android:drawable="@drawable/buttonbar_icon_eq_n" />
        </layer-list>
    </item>

    <!-- 默认状态 -->
    <item>
        <layer-list>
            <item android:drawable="@drawable/buttonbar_icon_eq_n" /> <!-- 图标 -->
        </layer-list>
    </item>
</selector>