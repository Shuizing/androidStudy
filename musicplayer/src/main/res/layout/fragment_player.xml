<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/music_background">


    <!--顶部信息区 -->
    <TextView
        android:id="@+id/tv_song_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Everybody Hurts"
        android:textSize="34sp"
        android:textColor="@color/song_tile"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <TextView
        android:id="@+id/tv_song_album"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Avril Lavigne\nGoodbye Lullaby"
        android:textAlignment="center"
        android:textSize="24sp"
        android:textColor="@color/song_album"
        android:lineSpacingMultiplier="1.2"
        app:layout_constraintTop_toBottomOf="@id/tv_song_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 右上角爱心 -->
    <ImageButton
        android:id="@+id/iv_favorite"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/selector_collect_icon"
        android:paddingLeft="15dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintStart_toEndOf="@id/tv_song_title"
        app:layout_constraintTop_toTopOf="@id/tv_song_title"
        app:layout_constraintBottom_toBottomOf="@id/tv_song_title"
        android:layout_marginEnd="8dp"/>



    <!-- 2. 核心播放区 (圆盘) -->
    <FrameLayout
        android:id="@+id/fl_container"
        android:layout_width="350dp"
        android:layout_height="350dp"
        app:layout_constraintTop_toBottomOf="@id/tv_song_album"
        app:layout_constraintBottom_toTopOf="@id/layout_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginVertical="20dp">


        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/id3_circle_area" />


        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="12dp"
            android:src="@drawable/id3_progressbar_area2" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="13dp"
            android:src="@drawable/id3_progressbar" />



        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="10dp"
            android:src="@drawable/id3_progressbar_area1" />


        <ImageView
            android:id="@+id/iv_pointer"
            android:layout_width="30dp"
            android:layout_height="18dp"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="12dp"
            android:src="@drawable/id3_progressbar_triangle" />




        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="28dp"
            android:src="@drawable/id3_artwork_area1"
            />



        <!-- ★ 动态风筝形指针 -->
        <!-- gravity=center → 旋转轴 = 图片中心 = 圆盘圆心 -->
        <!-- match_parent + margin=12dp → 让指针大小覆盖整个轨道区域 -->
        <ImageView
            android:id="@+id/iv_pointer_rotating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="12dp"
            android:src="@drawable/id3_progressbar_triangle1"
            android:scaleType="fitCenter" />



        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="65dp"
            android:src="@drawable/id3_artwork_area2" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|bottom"
            android:layout_margin="40dp"
            android:text="Song Title"
            android:textColor="@color/black"
            android:textSize="20sp" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="80dp"
            android:src="@drawable/id3_artwork" />
<!--        android:src="@drawable/selector_button_pause"-->
        <ImageButton
            android:id="@+id/ibtn_play"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/selector_id3_button_play"
            android:scaleX="0.7"
            android:scaleY="0.7"
            android:layout_gravity="center"
            android:background="@android:color/transparent" />



    </FrameLayout>



    <!-- 底部控制按钮区 -->
    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fl_container"
        android:layout_marginBottom="20dp">

        <!-- 循环模式 -->
        <ImageButton
            android:id="@+id/btn_repeat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/selector_repeat"
            android:background="@drawable/selector_id3_button_background"
            android:layout_marginHorizontal="8dp"
            android:scaleX="0.7"
            android:scaleY="0.7"
            />

        <!-- 上一曲 -->
        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/selector_prev"
            android:background="@drawable/selector_id3_button_background"
            android:layout_marginHorizontal="8dp"
            android:scaleX="0.7"
            android:scaleY="0.7"
            />

        <!-- 下一曲 -->
        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/selector_next"
            android:background="@drawable/selector_id3_button_background"
            android:layout_marginHorizontal="8dp"
            android:scaleX="0.7"
            android:scaleY="0.7"
            />

        <!-- 随机播放 -->
        <ImageButton
            android:id="@+id/btn_shuffle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:src="@drawable/selector_shuffle_on"
            android:background="@drawable/selector_id3_button_background"
            android:layout_marginHorizontal="8dp"
            android:scaleX="0.7"
            android:scaleY="0.7"
            />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>